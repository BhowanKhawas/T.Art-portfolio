doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Cinematic Gallery | Tisa Shrestha
    link(rel="stylesheet", href="assets/css/presentation.css")
  body.slideshow-mode
    nav
      a(href="index.html") ← Gallery
      a(href="about.html") About

    main.slideshow-container
      each art, index in artworks
        //- Each slide stays for 6 seconds, total duration = 52 * 6 = 312s
        .slide(style=`animation-delay: ${index * 6}s`)
          img(src=art.imageUrl, alt=art.title)
          .caption
            h1= art.title
            p= art.description
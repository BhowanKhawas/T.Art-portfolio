doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Tisa Shrestha | Art Portfolio
    link(rel="stylesheet", href="assets/css/style.css")
  body
    nav
      a(href="about.html") About
      a(href="index.html") Gallery
      a(href="presentation.html") Presentation

    header.hero-header
    h1 Tisa (Dilasha) Shrestha
    p Visual Artist Portfolio

    main#gallery-container
      each item in artworks
        article.art-piece
          a(href=`view-${item.id}.html`)
            img(src=item.imageUrl, alt=item.title)
          h2= item.title
          p= item.description